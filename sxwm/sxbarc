# layout and style
bottom_bar          : false
height              : 25
vertical_padding    : 0
horizontal_padding  : 0
text_padding        : 0
border              : false
border_width        : 0
background_colour   : #2E3440
foreground_colour   : #D8DEE9
border_colour       : #717394
font                : JetBrainsMono Nerd Font
font_size           : 14

